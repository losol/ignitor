{
  "name": "ignis-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "npm run paraglide:compile && react-router typegen && eslint .",
    "paraglide:compile": "paraglide-js compile --project ./app/i18n/project.inlang --outdir ./app/i18n/paraglide --emit-ts-declarations --strategy url cookie preferredLanguage baseLocale",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run paraglide:compile && react-router typegen && tsc"
  },
  "dependencies": {
    "@eventuras/fides-auth": "^0.7.1",
    "@eventuras/logger": "^0.8.1",
    "@eventuras/ratio-ui": "^2.3.0",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "isbot": "^5.1.31",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-router": "7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.18.0",
    "@inlang/plugin-m-function-matcher": "^2.2.6",
    "@inlang/plugin-message-format": "^4.4.0",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.5"
  }
}
