{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [{ "Name": "Console" }]
  },
  "AllowedHosts": "localhost",
  "ImportSettings": {
    "MaxUploadSizeBytes": 52428800,
    "MaxArchiveUncompressedBytes": 524288000,
    "MaxEntryUncompressedBytes": 52428800
  },
  "StoreSettings": {
    "ConnectionString": "mongodb://localhost:27017/ignis"
  },
  "AuthSettings": {
    "ConnectionString": "mongodb://localhost:27017/ignis",
    "Clients": [
      {
        "ClientId": "ignis-client",
        "ClientSecret": "replace-this-secret",
        "DisplayName": "Ignis Client",
        "AllowedGrantTypes": ["client_credentials"]
      }
    ],
    "Endpoints": {
      "LoginPath": "connect/login"
    }
  },
  "SparkSettings": {
    "Endpoint": "https://localhost:5201/fhir",
    "FhirRelease": "R4",
    "UseAsynchronousIO": true,
    "ParserSettings": {
      "AcceptUnknownMembers": true,
      "AllowUnrecognizedEnums": true,
      "PermissiveParsing": true
    },
    "SerializerSettings": {
      "Pretty": true,
      "AppendNewLine": false
    }
  }
}
